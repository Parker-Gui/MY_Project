page {
  min-height: 100vh;
  background: #111111;
}

.scene-add-page {
  min-height: 100vh;
  color: #ffffff;
  background: #111111;
}

.scene-add-scroll {
  height: calc(100vh - 1px);
}

.scene-add-content {
  min-height: 100vh;
  padding: 42rpx 32rpx 76rpx;
  box-sizing: border-box;
  background: linear-gradient(115deg, #171717 0%, #2c2c2c 56%, #151515 100%);
}

.panel-handle {
  width: 56rpx;
  height: 8rpx;
  margin: 36rpx auto 56rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.76);
}

.page-title {
  display: block;
  font-size: 52rpx;
  line-height: 72rpx;
  font-weight: 700;
}

.total-volume-card {
  height: 120rpx;
  display: flex;
  align-items: center;
  margin-top: 62rpx;
  padding: 0 28rpx;
  border-radius: 56rpx;
  background: rgba(255, 255, 255, 0.18);
  box-sizing: border-box;
}

.total-volume-title {
  margin-right: 28rpx;
  font-size: 38rpx;
  line-height: 52rpx;
  font-weight: 700;
}

.volume-icon,
.row-volume-icon {
  width: 42rpx;
  height: 42rpx;
  flex: none;
}

.total-volume-slider {
  flex: 1;
  margin: 0 20rpx;
}

.volume-value {
  width: 90rpx;
  font-size: 32rpx;
  line-height: 44rpx;
  text-align: right;
}

.sound-list {
  margin-top: 44rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.08);
}

.sound-row {
  min-height: 174rpx;
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
}

.sound-cover {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  flex: none;
  border-radius: 50%;
  border: 8rpx solid rgba(155, 155, 155, 0.9);
  box-sizing: border-box;
}

.sound-cover-bg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #6fc36a 0%, #d9f2a5 42%, #8cc9f0 100%);
}

.cover-bg-0 {
  background: linear-gradient(135deg, #d8edf9 0%, #ffffff 40%, #87afd0 100%);
}

.cover-bg-1 {
  background: linear-gradient(135deg, #f1e6d4 0%, #c99862 48%, #ffffff 100%);
}

.cover-bg-2 {
  background: linear-gradient(135deg, #d7e6f4 0%, #ffffff 40%, #516778 100%);
}

.sound-cover-hole {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #303030;
  transform: translate(-50%, -50%);
}

.sound-delete {
  position: absolute;
  right: -18rpx;
  top: -18rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e92710;
  color: #ffffff;
  font-size: 40rpx;
  line-height: 44rpx;
}

.sound-control {
  flex: 1;
  min-width: 0;
  margin-left: 34rpx;
}

.sound-control-line {
  display: flex;
  align-items: center;
}

.row-slider {
  flex: 1;
  margin: 0 20rpx;
}

.row-volume-value {
  width: 86rpx;
  color: #ffffff;
  font-size: 32rpx;
  line-height: 44rpx;
  text-align: right;
}

.sound-switch {
  margin-left: 24rpx;
  transform: scale(0.82);
  transform-origin: right center;
}

.action-row {
  display: flex;
  justify-content: space-between;
  margin-top: 72rpx;
  padding-bottom: 24rpx;
}

.save-button,
.reset-button {
  width: 320rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 58rpx;
  font-size: 42rpx;
  line-height: 58rpx;
}

.save-button {
  background: #2d86ff;
  color: #ffffff;
}

.reset-button {
  background: rgba(255, 255, 255, 0.62);
  color: #303030;
}

.save-button::after,
.reset-button::after {
  border: 0;
}
