page {
  min-height: 100vh;
  background: #111111;
}

.scene-add-page {
  position: relative;
  min-height: 100vh;
  color: #ffffff;
  background: #111111;
}

.scene-add-back {
  position: fixed;
  left: 24rpx;
  top: calc(env(safe-area-inset-top) + 86rpx);
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 46rpx;
  line-height: 60rpx;
  z-index: 99;
}

.scene-add-scroll {
  height: calc(100vh - 1px);
}
