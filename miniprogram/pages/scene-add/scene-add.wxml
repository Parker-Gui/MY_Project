<view class="scene-add-page">
  <navigation-bar title="增加一场景" back="{{true}}" color="#FFFFFF" background="transparent" bindback="handleBack"></navigation-bar>
  <view class="scene-add-back" bindtap="handleBack">←</view>

  <scroll-view class="scene-add-scroll" scroll-y type="list">
    <scene-channel-editor
      title="增加-场景{{sceneNumber}}"
      total-volume="{{totalVolume}}"
      channels="{{soundItems}}"
      variant="page"
      show-actions="{{true}}"
      bindtotalvolumechange="handleTotalVolumeChange"
      bindchannelvolumechange="handleSoundVolumeChange"
      bindstatuschange="handleSoundSwitchChange"
      bindmusicselect="handleOpenChannelSetting"
      bindchanneldelete="handleDeleteSound"
      bindsave="handleSave"
      bindreset="handleReset"
    ></scene-channel-editor>
  </scroll-view>
</view>
