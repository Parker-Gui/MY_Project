page {
  min-height: 100vh;
  background: #111111;
}

.debug-page {
  min-height: 100vh;
  background: #111111;
  color: #ffffff;
}

.debug-scroll {
  height: calc(100vh - 1px);
}

.debug-content {
  padding: 132rpx 28rpx 54rpx;
  box-sizing: border-box;
}

.debug-section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
}

.section-title {
  margin-bottom: 22rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 42rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-top: 16rpx;
}

.info-label {
  width: 150rpx;
  color: rgba(255, 255, 255, 0.54);
  font-size: 24rpx;
  line-height: 36rpx;
}

.info-value {
  flex: 1;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 38rpx;
  text-align: right;
  word-break: break-all;
}

.info-code,
.code-line,
.log-hex {
  font-family: Menlo, Consolas, monospace;
}

.code-line {
  display: block;
  padding: 20rpx;
  margin-top: 12rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.24);
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  line-height: 34rpx;
  word-break: break-all;
}

.action-row {
  display: flex;
  margin-bottom: 24rpx;
}

.debug-button {
  flex: 1;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 38rpx;
  background: #2d86ff;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 36rpx;
}

.debug-button-danger {
  background: #f31b33;
  margin-left: 18rpx;
}

.empty-log {
  padding: 34rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
  line-height: 38rpx;
  text-align: center;
}

.log-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(51, 211, 128, 0.1);
  border: 2rpx solid rgba(51, 211, 128, 0.22);
}

.log-card-fail {
  background: rgba(243, 27, 51, 0.1);
  border-color: rgba(243, 27, 51, 0.26);
}

.log-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  line-height: 32rpx;
}

.log-hex {
  display: block;
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 34rpx;
  word-break: break-all;
}

.log-message {
  display: block;
  margin-top: 10rpx;
  color: #ff9aa4;
  font-size: 22rpx;
  line-height: 34rpx;
  word-break: break-all;
}
