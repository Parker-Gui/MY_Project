<view class="scene-editor {{variant === 'sheet' ? 'scene-editor-sheet' : 'scene-editor-page'}}">
  <view wx:if="{{showHandle}}" class="panel-handle" bindtap="handleClose"></view>
  <text class="editor-title">{{title}}</text>

  <view class="total-volume-card">
    <text class="total-volume-title">总音量</text>
    <image class="volume-icon" src="/pages/home/sound.png" mode="aspectFit"></image>
    <slider
      class="total-volume-slider"
      min="0"
      max="100"
      value="{{totalVolume}}"
      block-size="30"
      activeColor="#2d86ff"
      backgroundColor="#ffffff"
      block-color="#2d86ff"
      bindchange="handleTotalVolumeChange"
      bindchanging="handleTotalVolumeChange"
    />
    <text class="volume-value">{{totalVolume}}%</text>
  </view>

  <scroll-view class="sound-scroll {{showActions ? 'sound-scroll-actions' : ''}}" scroll-y type="list">
    <view class="sound-list">
      <view
        class="sound-row"
        wx:for="{{channels}}"
        wx:key="id"
      >
        <view class="sound-cover" data-id="{{item.id}}" catchtap="handleMusicTap">
          <view class="sound-cover-bg cover-bg-{{item.coverIndex % 3}}"></view>
          <view class="sound-cover-hole"></view>
          <image class="sound-music-icon" src="/pages/home/music-icon.png" mode="aspectFit"></image>
          <view wx:if="{{item.removable}}" class="sound-delete" data-id="{{item.id}}" catchtap="handleDeleteTap">×</view>
        </view>

        <image class="row-volume-icon" src="/pages/home/sound.png" mode="aspectFit"></image>
        <slider
          class="row-slider"
          min="0"
          max="100"
          value="{{item.volume}}"
          block-size="28"
          activeColor="{{item.status === 1 || item.enabled ? '#2d86ff' : '#ffffff'}}"
          backgroundColor="#ffffff"
          block-color="#2d86ff"
          data-id="{{item.id}}"
          bindchange="handleChannelVolumeChange"
          bindchanging="handleChannelVolumeChange"
        />
        <text class="row-volume-value">{{item.volume}}%</text>
        <view
          class="sound-switch {{item.status === 1 || item.enabled ? 'sound-switch-on' : ''}}"
          data-id="{{item.id}}"
          bindtap="handleStatusTap"
        >
          <view class="sound-switch-thumb"></view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{showActions}}" class="action-row">
    <button class="save-button" bindtap="handleSave">保存</button>
    <button class="reset-button" bindtap="handleReset">重置</button>
  </view>
</view>
